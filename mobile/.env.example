# Expo Push / EAS — required for getExpoPushTokenAsync (see app.config.js).
# Run `npx eas-cli@latest init` in the mobile folder, then copy Project ID from the dashboard or eas.json.
# EXPO_PUBLIC_EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Shopify Storefront API (required for store + checkout)
# Expo inlines only variables prefixed with EXPO_PUBLIC_ into the JS bundle.
# Use these in .env for local development (e.g. `npx expo start`).

EXPO_PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com
EXPO_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_access_token

# Optional: menu handle for collection navigation (defaults to main-menu)
# EXPO_PUBLIC_SHOPIFY_MENU_HANDLE=main-menu

# קולקציית «חברות נבחרות» לפי handle מ-Shopify — רצועת סטוריז בדף הבית (נפרד מהבנטו)
# EXPO_PUBLIC_HOME_SELECTED_BRANDS_COLLECTION_HANDLE=your-collection-handle

# --- Aliases (also read by `src/lib/shopify.ts` if set with EXPO_PUBLIC_) ---
# EXPO_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# EXPO_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_access_token

# --- Non-public names (only work if your build injects them into the client bundle) ---
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_access_token
